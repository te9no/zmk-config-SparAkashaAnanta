#include <behaviors/animation_trigger.dtsi>
#include <behaviors/animation_control.dtsi>
#include <dt-bindings/led/led.h>
#include <dt-bindings/zmk_driver_animation/animation_control.h>
#include <dt-bindings/zmk_driver_animation/animation_trigger.h>
#include <zmk_driver_animation/animation.dtsi>
#include <zmk_driver_animation/animation_layer_status.dtsi>

#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <behaviors/rgbled_widget.dtsi>

/ {
	chosen {
		zmk,physical-layout = &layout_SAA;
      zmk,battery = &vbatt;
		zmk,animation = &animation_control;
		zmk,animation-control = &animation_control;
	};

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <12>;
		rows = <5>;

		map = <
		RC( 1, 0)  RC( 2, 0)  RC( 3, 0)  RC( 4, 0)  RC( 5, 0)  RC( 2, 1)     RC( 2, 7)  RC( 5, 6)  RC( 4, 6)  RC( 3, 6)  RC( 2, 6)  RC( 1, 6)
		RC( 0, 2)  RC( 1, 2)  RC( 3, 2)  RC( 4, 2)  RC( 5, 2)  RC( 3, 1)     RC( 3, 7)  RC( 5, 8)  RC( 4, 8)  RC( 3, 8)  RC( 1, 8)  RC( 0, 8)
		RC( 0, 3)  RC( 1, 3)  RC( 2, 3)  RC( 4, 3)  RC( 5, 3)  RC( 4, 1)     RC( 4, 7)  RC( 5, 9)  RC( 4, 9)  RC( 2, 9)  RC( 1, 9)  RC( 0, 9)
		RC( 0, 4)  RC( 1, 4)  RC( 2, 4)             RC( 3, 4)  RC( 5, 4)     RC( 5,10)  RC( 3,10)             RC( 2,10)  RC( 1,10)  RC( 0,10)
                 RC( 3, 5)  RC( 2, 5)  RC( 4, 5)  RC( 1, 5)  RC( 0, 5)     RC( 1,11)  RC( 3,11)  RC( 4,11)  RC( 0,11)  RC( 2,11)
      RC( 6, 0)                                                            RC( 6, 6)
		>;
	};

	layout_SAA: layout_SAA {
		compatible = "zmk,physical-layout";
		display-name = "SAA";
		transform = <&default_transform>;
		kscan = <&kscan0>;

      keys  //                     w   h    x    y     rot    rx    ry
         = <&key_physical_attrs 100 100  149 (-183)    1500   149 (-183)>
         , <&key_physical_attrs 100 100  252 (-200)    1500   152 (-200)>
         , <&key_physical_attrs 100 100  454 (-209)    1500   254 (-209)>
         , <&key_physical_attrs 100 100  358 (-243)    1500    58 (-243)>
         , <&key_physical_attrs 100 100  566 (-235)    1500   166 (-235)>
         , <&key_physical_attrs 100 100  671 (-235)    1500   171 (-235)>
         , <&key_physical_attrs 100 100  987  205 (-1500) (-113)   205>
         , <&key_physical_attrs 100 100 1090  205 (-1500) (-110)   205>
         , <&key_physical_attrs 100 100 1190  205 (-1500) (-110)   205>
         , <&key_physical_attrs 100 100 1293  222 (-1500) (-107)   222>
         , <&key_physical_attrs 100 100 1396  239 (-1500) (-104)   239>
         , <&key_physical_attrs 100 100 1499  256 (-1500) (-101)   256>
         , <&key_physical_attrs 100 100  129 (-69)     500   129 (-169)>
         , <&key_physical_attrs 100 100  229 (-69)     500   129 (-169)>
         , <&key_physical_attrs 100 100  428 (-60)     500   228 (-160)>
         , <&key_physical_attrs 100 100  329 (-78)     500    29 (-178)>
         , <&key_physical_attrs 100 100  533 (-52)     500   133 (-152)>
         , <&key_physical_attrs 100 100  636 (-35)     500   136 (-135)>
         , <&key_physical_attrs 100 100  971  113  (-500) (-129)    13>
         , <&key_physical_attrs 100 100 1071   96  (-500) (-129)  (-4)>
         , <&key_physical_attrs 100 100 1168   79  (-500) (-132) (-21)>
         , <&key_physical_attrs 100 100 1268   79  (-500) (-132) (-21)>
         , <&key_physical_attrs 100 100 1368   79  (-500) (-132) (-21)>
         , <&key_physical_attrs 100 100 1468   79  (-500) (-132) (-21)>
         , <&key_physical_attrs 100 100   94   48  (-500)    94 (-152)>
         , <&key_physical_attrs 100 100  194   66  (-500)    94 (-134)>
         , <&key_physical_attrs 100 100  294   83  (-500)    94 (-117)>
         , <&key_physical_attrs 100 100  394  101  (-500)    94 (-99)>
         , <&key_physical_attrs 100 100  499  135  (-500)    99 (-65)>
         , <&key_physical_attrs 100 100  601  170  (-500)   101 (-30)>
         , <&key_physical_attrs 100 100 1006   22     500 (-94) (-178)>
         , <&key_physical_attrs 100 100 1106 (-13)     500 (-94) (-213)>
         , <&key_physical_attrs 100 100 1203 (-48)     500 (-97) (-248)>
         , <&key_physical_attrs 100 100 1303 (-65)     500 (-97) (-265)>
         , <&key_physical_attrs 100 100 1403 (-83)     500 (-97) (-283)>
         , <&key_physical_attrs 100 100 1503 (-100)     500 (-97) (-300)>
         , <&key_physical_attrs 100 100   45  192 (-1500)    45 (-108)>
         , <&key_physical_attrs 100 100  142  227 (-1500)    42 (-73)>
         , <&key_physical_attrs 100 100  251  261 (-1500)    51 (-39)>
         , <&key_physical_attrs 100 100  525  225       0    50 (-75)>
         , <&key_physical_attrs 100 100 1075  225       0 (-50) (-75)>
         , <&key_physical_attrs 100 100 1397 (-179)    1500  (-3) (-479)>
         , <&key_physical_attrs 100 100 1500 (-214)    1500     0 (-514)>
         , <&key_physical_attrs 100 100 1603 (-248)    1500     3 (-548)>
         , <&key_physical_attrs 100 100  625  225       0    50 (-100)>
         , <&key_physical_attrs  50  50  725  325       0     0     0>
         , <&key_physical_attrs  50  50  925  325       0     0     0>
         , <&key_physical_attrs 100 100  975  225       0 (-50) (-100)>
         , <&key_physical_attrs  50  50  675  375       0     0     0>
         , <&key_physical_attrs  50  50  725  375       0     0     0>
         , <&key_physical_attrs  50  50  775  375       0     0     0>
         , <&key_physical_attrs  50  50  875  375       0     0     0>
         , <&key_physical_attrs  50  50  925  375       0     0     0>
         , <&key_physical_attrs  50  50  975  375       0     0     0>
         , <&key_physical_attrs  50  50  725  425       0     0     0>
         , <&key_physical_attrs  50  50  925  425       0     0     0>
         , <&key_physical_attrs 100 100  335  300       0     0     0>
         , <&key_physical_attrs 100 100 1260  300       0     0     0>
         ;
   };

    position_map {
        compatible = "zmk,physical-layout-position-map";

        layout_SAA {
            physical-layout = <&layout_SAA>;
            positions = <>;
        };
    };

   aliases {
      led-red = &led0;
      led-green = &led1;
      led-blue = &led2;
   };

   leds {
      compatible = "gpio-leds";
      status = "okay";
      led0: led_0 {
        gpios = <&gpio0 26 GPIO_ACTIVE_LOW>;  // red LED, connected to P0.26
      };
      led1: led_1 {
        gpios = <&gpio0 30 GPIO_ACTIVE_LOW>;  // green LED, connected to P0.30
      };
      led2: led_2 {
        gpios = <&gpio0 6 GPIO_ACTIVE_LOW>;  // blue LED, connected to P0.06
      };
   };


	animation: animation {
		compatible = "zmk,animation";
		drivers = <&led_strip>;
		pixels = <&pixel 0 0>,
		<&pixel 1 0>,
		<&pixel 2 0>,
		<&pixel 3 0>;
		chain-lengths = <4>;
	};
	
	animations {
		/omit-if-no-ref/ animation_control: control {
			compatible = "zmk,animation-control";
			label = "ANIMATION_CTRL_0";
			powered-animations = <&endpoint_status_animation &rainbow_animation>;
			battery-animations = <&empty_animation>;
			behavior-animations = <&battery_status_animation &endpoint_status_animation &animation_layer_status>;
			init-animation = <&init_animation>;
			activation-animation = <&battery_status_animation>;
			activation-animation-duration-ms = <1000>;
			ext-power = <&led_power>;
		};
		/omit-if-no-ref/ init_animation: init {
			compatible = "zmk,animation-compose";
			animations = <&battery_status_animation &black_animation &endpoint_status_animation>;
			durations-ms = <1000 200 1000>;
		};
		/omit-if-no-ref/ black_animation: black {
			compatible = "zmk,animation-solid";
			pixels = <0 1 2 3>;
			colors = <HSL(0, 0, 0)>;
		};
		
		/omit-if-no-ref/ empty_animation: empty {
			compatible = "zmk,animation-empty";
			status = "okay";
		};
		/omit-if-no-ref/ rainbow_animation: rainbow {
			compatible = "zmk,animation-solid";
			status = "okay";
			pixels = <0 1 2 3>;
			colors = <HSL(0, 100, 50) HSL(60, 100, 50) HSL(120, 100, 50) HSL(180, 100, 50) HSL(240, 100, 50) HSL(300, 100, 50)>;
		};
		/omit-if-no-ref/ red_animation: red {
			compatible = "zmk,animation-solid";
			status = "okay";
			pixels = <0 1 2 3>;
			colors = <HSL(0, 100, 50)>;
		};
		/omit-if-no-ref/ endpoint_status_animation: endpoint_status {
			compatible = "zmk,animation-endpoint";
			status = "okay";
			pixels = <0 1 2 3>;
			color-open = <HSL(60, 100, 50)>;
			color-connected = <HSL(240, 100, 50)>;
			color-disconnected = <HSL(0, 100, 50)>;
			color-usb = <HSL(120, 100, 25)>;
		};
		/omit-if-no-ref/ battery_status_animation: battery_status {
			compatible = "zmk,animation-battery-status";
			status = "okay";
			pixels = <0 1 2 3>;
			color-high = <HSL(120, 100, 50)>;// green
			color-middle = <HSL(60, 100, 50)>;// yellow
			color-low = <HSL(0, 100, 50)>;// red
		};
	};
   
	led_power:led_power {
		compatible = "zmk,ext-power-transient";
		control-gpios = <&gpio0 4 (GPIO_ACTIVE_LOW)>;
	};

   // Encoders
   left_encoder: left_encoder {
      compatible = "alps,ec11";
      status = "disabled";
   };

   right_encoder: right_encoder {
      compatible = "alps,ec11";
      status = "disabled";
   };

   sensors: sensors {
      compatible = "zmk,keymap-sensors";
      sensors = <&left_encoder &right_encoder>;
   };

    vbatt: vbatt {
        io-channels = <&adc 0>;
        power-gpios; // unset
        output-ohms = <470000>;
        full-ohms = <(1000000 + 470000)>;
        // For Ni-Mh 1U
        mv-to-pct-thresholds = <1100 1150 1200 1220 1240 1260 1280 1300 1320 1350 1400>;
    };
};

&adc {
   status = "okay";
};

//
// pinctrl for LED strip (WS2812 2020)
//

&pinctrl {
	spi3_default: spi3_default {
		group1 {
			psels = <NRF_PSEL(SPIM_MOSI, 0, 10)>;// D1
		};
	};
	
	spi3_sleep: spi3_sleep {
		group1 {
			psels = <NRF_PSEL(SPIM_MOSI, 0, 10)>;
			low-power-enable;
		};
	};
};

&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	
	pinctrl-0 = <&spi3_default>;
	pinctrl-1 = <&spi3_sleep>;
	pinctrl-names = "default", "sleep";
	
	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		reg = <0>;
		// Note: Frequency should be between 2.5MHz to 5MHz
		// 2.5MHz := 1sec / 0.4us
		//           where 0.4us is min (T0H max, T0L max, T1H max, T1L max)
		//                 T0H max = 0.4us, T1H max = 1.0us, T0L,T1L max = 20us
		// 5MHz := min(1sec / 0.2us, 1sec / 1.2us * 8bit)
		//           where 0.2us is min (T0H min, T0L min, T1H min, T1L min)
		//                               T0H min = 0.2us, T1L min = 0.2us, T1H min = 0.58us, T0L min = 0.8us
		//                 1.2us is T min
		//                 8bit is because this driver builds 1frame with 8bit (spi-one-frame, spi-zero-frame)
		spi-max-frequency = <4000000>;// 4MHz = 0.25us
		
		chain-length = <4>; /* number of LEDs */
		spi-one-frame = <0x70>;// 01110000 -> T1H = 0.25 * 3 = 0.75us is between 0.58 and 1.0
		spi-zero-frame = <0x40>;// 01000000 -> T0H = 0.25us is between 0.2 and 0.4
		color-mapping = <LED_COLOR_ID_GREEN
		LED_COLOR_ID_RED
		LED_COLOR_ID_BLUE>;
	};
};

&animation_layer_status {
	pixels = <0 1 2 3>;
	default-color = <HSL(240, 100, 50)>;
	// default
	// windows blue
	// mac red
	// ios white
	// linux orange
	colors = <
	0
	HSL(193, 100, 47)
	HSL(0, 100, 40)
	HSL(0, 100, 100)
	HSL(29, 88, 51)
	>;
};
