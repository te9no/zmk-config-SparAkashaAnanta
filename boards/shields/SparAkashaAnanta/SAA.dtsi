#include "SAA_pins.dtsi"
#include "SAA_layout.dtsi"
#include "SAA_led.dtsi"
#include "SAA_oled.dtsi"

/ {
	chosen {
		zmk,battery = &vbatt;
	};

	behaviors {
		dbg_tog: debug_toggle {
			compatible = "zmk,behavior-debug-toggle";
			#binding-cells = <0>;
			display-name = "Debug Toggle";
		};
	};

	// Encoders
	left_encoder: left_encoder {
		compatible = "alps,ec11";
		status = "disabled";
	};

	right_encoder: right_encoder {
		compatible = "alps,ec11";
		status = "disabled";
	};

	sensors: sensors {
		compatible = "zmk,keymap-sensors";
		sensors = <&left_encoder &right_encoder>;
	};

	saa_module_detector: module_detector {
		compatible = "saa,module-detector";
		status = "okay";
		id-gpios = MODULE_ID0_GPIOS, MODULE_ID1_GPIOS;
		module-names = "KEY", "ENC", "JOY", "POINTING";
	};

	vbatt: vbatt {
		io-channels = BATTERY_CHANNEL;
		power-gpios; // unset
		output-ohms = <470000>;
		full-ohms = <(1000000 + 470000)>;
		// For Ni-Mh 1U
		mv-to-pct-thresholds = <1100 1150 1200 1220 1240 1260 1280 1300 1320 1350 1400>;
	};
};

&adc {
	status = "okay";
};
