menuconfig ZMK_INPUT_MODULE
	bool "ZMK input module profile selection"
	default y
	depends on DT_HAS_ZMK_INPUT_MODULE_MUX_ENABLED
	select SETTINGS
	help
	  Provides runtime selection and settings persistence for keyboards that
	  support multiple mutually-exclusive input module profiles.

if ZMK_INPUT_MODULE

config ZMK_INPUT_MODULE_SETTINGS_INIT_PRIORITY
	int "ZMK input module settings init priority"
	default 89
	help
	  Application init priority used to restore the selected input module
	  profile before ZMK keymap, sensor, and physical layout initialization.

config ZMK_INPUT_MODULE_SENSOR_PROXY
	bool "ZMK input module sensor proxy"
	default y
	depends on SENSOR
	depends on DT_HAS_ZMK_INPUT_MODULE_SENSOR_PROXY_ENABLED
	help
	  Provides a sensor device that delegates to the selected input module's
	  deferred sensor candidate.

config ZMK_INPUT_MODULE_SELECT_BEHAVIOR
	bool "ZMK input module select behavior"
	default y
	depends on DT_HAS_ZMK_BEHAVIOR_INPUT_MODULE_SELECT_ENABLED
	help
	  Enables a behavior that stores the selected input module profile.

module = ZMK_INPUT_MODULE
module-str = zmk_input_module
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

endif
